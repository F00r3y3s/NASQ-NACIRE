# Base application URL used for metadata, links, and local development.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional showcase mode for public pages when you want client-demo content
# before real platform records exist.
NASQ_ENABLE_DEMO_DATA=false

# Populate these before enabling Supabase-backed features in later tickets.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Reserved for privileged server-side workflows that arrive in later tickets.
SUPABASE_SERVICE_ROLE_KEY=

# Optional AI provider configuration for grounded retrieval and draft assist.
OPENAI_API_KEY=
OPENAI_BASE_URL=
NASQ_AI_RESPONSE_MODEL=gpt-5.4
NASQ_AI_EMBEDDING_MODEL=text-embedding-3-small
